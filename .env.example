# PSB Maintenance Hub - Environment Configuration
# Copy this to .env and fill in your values

# Server
PORT=3001
JWT_SECRET=your-secret-key-change-this-in-production

# WhatsApp Business Cloud API (Meta)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# LLM Configuration (set your preferred default)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key

# Email (SMTP for sending escalation emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ESCALATION_EMAIL=admin@52oldelvet.com

# Google OAuth (Gmail drafts and Google Calendar)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://maintenance.52oldelvet.com/api/email/accounts/gmail/callback
GOOGLE_CALENDAR_REDIRECT_URI=https://maintenance.52oldelvet.com/api/calendar/google/callback

# Admin Default Credentials (change after first login)
ADMIN_EMAIL=admin@52oldelvet.com
ADMIN_PASSWORD=changeme123
