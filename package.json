{
  "name": "psb-maintenance-hub",
  "version": "1.0.0",
  "description": "PSB Properties Maintenance Hub - WhatsApp Bot & Management Dashboard",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "setup": "node server/setup.js",
    "build": "cd client && npm install --include=dev && npm run build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.7.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "googleapis": "^126.0.0",
    "uuid": "^9.0.0",
    "xlsx": "^0.18.5"
  }
}
