{
  "name": "psb-maintenance-hub",
  "version": "1.0.0",
  "description": "PSB Properties Maintenance Hub - WhatsApp Bot & Management Dashboard",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "setup": "node server/setup.js",
    "build": "cd client && npm install --include=dev && npm run build",
    "start": "node server/index.js",
    "desktop:dev": "npm run build && electron desktop/main.cjs",
    "desktop:pack:mac": "npm run build && electron-builder --mac dir",
    "desktop:zip:mac": "npm run desktop:pack:mac && node desktop/zip-mac.cjs",
    "desktop:dist:mac": "npm run build && electron-builder --mac dmg",
    "desktop:rebuild": "electron-builder install-app-deps",
    "agent": "node scripts/ffr-agent.js",
    "agent:list": "node scripts/ffr-agent.js list",
    "agent:health": "node scripts/ffr-agent.js health"
  },
  "dependencies": {
    "@openai/codex": "^0.130.0",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.7.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "googleapis": "^126.0.0",
    "imap-simple": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.6.5",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "uuid": "^9.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.ffrgroup.propertyos",
    "productName": "FFR Property OS",
    "asar": false,
    "files": [
      "desktop/**/*",
      "server/**/*",
      "client/dist/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "extraMetadata": {
      "main": "desktop/main.cjs"
    },
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "artifactName": "FFR-Property-OS-${version}-${arch}.dmg"
    }
  }
}
